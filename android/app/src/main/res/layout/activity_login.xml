<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#F7F7FF"
    android:padding="40dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="君华云呼"
        android:textSize="28sp"
        android:textColor="#0090FF"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="坐席登录"
        android:textSize="14sp"
        android:textColor="#909399"
        android:layout_marginBottom="40dp" />

    <EditText
        android:id="@+id/et_agent_id"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_input"
        android:hint="坐席ID (agent01)"
        android:padding="16dp"
        android:textSize="15sp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/et_password"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_input"
        android:hint="密码 (123456)"
        android:padding="16dp"
        android:textSize="15sp"
        android:inputType="textPassword"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FF4D4F"
        android:textSize="13sp"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="登 录"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#0090FF"
        android:layout_marginTop="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="测试账号: agent01 / 123456"
        android:textSize="12sp"
        android:textColor="#C0C4CC" />

</LinearLayout>
